<%- include('../partials/header') %>

<section class="text-center">
  <h2>📚 Blog Posts</h2>
  <p class="mb-3">Explore tips, tools, and stories for freelancers and remote workers.</p>

  <% if (posts.length === 0) { %>
    <p class="alert alert-danger">No blog posts found.</p>
  <% } %>

  <% posts.forEach(post => { %>
    <div class="blog-post mb-3">
      <h2><a href="/blog/<%= post.slug %>"><%= post.title %></a></h2>
      <p class="text-muted mb-1"><%= post.date %></p>
      <p><%= post.description %></p>
      <a href="/blog/<%= post.slug %>" class="btn mt-1">Read More</a>
    </div>
  <% }) %>
</section>

<%- include('../partials/footer') %>
