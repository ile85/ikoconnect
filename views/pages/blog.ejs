<%- include('../partials/header') %>

<section>
  <h2>IkoConnect Blog</h2>
  <p>Tips, tutorials, and insights from the freelance world.</p>

  <% if (posts && posts.length > 0) { %>
    <% posts.forEach(post => { %>
      <article class="blog-post">
        <h3><%= post.title %></h3>
        <p><%= post.content %></p>
      </article>
    <% }) %>
  <% } else { %>
    <p>No blog posts yet. Stay tuned!</p>
  <% } %>
</section>

<%- include('../partials/footer') %>
