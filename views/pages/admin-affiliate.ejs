<%- include('../partials/header') %>

<section class="admin-panel">
  <div class="admin-left">
    <h2 class="text-center mb-2">🔧 Admin Panel: Add Affiliate Tool</h2>

    <% if (message) { %>
      <div class="alert alert-success text-center"><%= message %></div>
    <% } %>

    <form action="/admin/affiliate" method="POST" class="admin-form mt-3">
      <label for="tool-name"><strong>Tool Name</strong></label>
      <input type="text" id="tool-name" name="name" placeholder="Tool Name" required autocomplete="off" />

      <div id="og-preview" class="mt-2">
        <label for="tool-name"><strong>🔍 OG Image Preview:</strong></label><br>
        <img id="og-image" src="" alt="OG Preview" style="max-width: 100%; border: 1px solid #ccc; padding: 5px; display: none;">
      </div>

      <input type="text" name="description" placeholder="Short Description" required autocomplete="off" />
      <input type="url" name="url" placeholder="Affiliate URL" required autocomplete="off" />
      <input type="text" name="logo" placeholder="Logo Path (e.g., /images/logos/fiverr.png)" required autocomplete="off" />

      <label for="markdown"><strong>✍️ Optional Markdown Content</strong></label>
      <textarea id="markdown" name="markdown" rows="8" placeholder="Write your custom content here..."></textarea>

      <div class="g-recaptcha mt-2" data-sitekey="6LfGQBcrAAAAAN0p4eMHPQ2gnTqpetUIAbHaVTZW"></div>

      <button type="submit" class="btn mt-2">➕ Add Tool</button>
    </form>
  </div>

  <div class="admin-right">
    <h4 class="mb-2">🔍 Live Preview</h4>
    <div id="markdown-preview" class="preview-box"></div>

    <hr class="mt-4 mb-3" />
    <h3 class="text-center mb-2">📋 Existing Tools</h3>
    <ul class="tool-list">
      <% tools.forEach(tool => { %>
        <li>
          <img src="<%= tool.logo %>" alt="<%= tool.name %>" class="icon-sm" />
          <div>
            <strong><%= tool.name %></strong><br />
            <a href="<%= tool.url %>" target="_blank">Link</a>
          </div>
          <form action="/admin/affiliate/delete" method="POST" style="margin-left:auto;">
            <input type="hidden" name="name" value="<%= tool.name %>" />
            <button type="submit" class="btn btn-outline" onclick="return confirm('Delete <%= tool.name %>?')">🗑 Delete</button>
          </form>
        </li>
      <% }) %>
    </ul>
  </div>
</section>

<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const nameInput = document.querySelector('input[name="name"]');
    const ogImage = document.getElementById('og-image');
    const input = document.getElementById("markdown");
    const preview = document.getElementById("markdown-preview");

    if (nameInput && ogImage) {
      nameInput.addEventListener("input", () => {
        const slug = nameInput.value.trim().toLowerCase().replace(/\s+/g, '-');
        const ogUrl = `/images/og/${slug}.png`;
        const fallback = `/images/og/default.png`;

        console.log("🔎 Checking OG Preview:", ogUrl);

        fetch(ogUrl).then(res => {
          ogImage.src = res.ok ? ogUrl : fallback;
          ogImage.style.display = "block";
        }).catch(err => {
          console.warn("❌ OG fetch error:", err);
          ogImage.src = fallback;
          ogImage.style.display = "block";
        });
      });
    }

    if (input && preview) {
      input.addEventListener("input", async () => {
        preview.style.opacity = 0.5;

        try {
          const res = await fetch("/api/markdown-preview", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ markdown: input.value }),
          });

          const data = await res.json();
          preview.innerHTML = data.html;
        } catch (err) {
          preview.innerHTML = "<p style='color:red'>❌ Failed to render preview</p>";
        } finally {
          preview.style.opacity = 1;
        }
      });
    }
  });
</script>

<style>
.markdown-preview-container {
  display: flex;
  gap: 1rem;
  margin-top: 1rem;
}
#markdown-input {
  width: 50%;
}
.preview-box {
  width: 50%;
  background: #f9f9f9;
  border: 1px solid #ddd;
  padding: 1rem;
  border-radius: 6px;
  overflow-y: auto;
  max-height: 300px;
}
</style>

<%- include('../partials/footer') %>
