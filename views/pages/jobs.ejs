<!-- views/pages/jobs.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Remote Jobs | IkoConnect</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <h1>Remote & Freelance Job Board</h1>
    <p>Find the latest hand-picked jobs for remote professionals.</p>
  </header>

  <main>
    <% if (jobs.length > 0) { %>
      <% jobs.forEach(job => { %>
        <div class="job-posting">
          <h2><%= job.title %></h2>
          <p><strong>Company:</strong> <%= job.company %></p>
          <p><strong>Location:</strong> <%= job.location %></p>
          <a href="<%= job.link %>" target="_blank" rel="noopener">View Job</a>
        </div>
        <hr />
      <% }) %>
    <% } else { %>
      <p>No job listings available at the moment.</p>
    <% } %>
  </main>

  <footer>
    <p>&copy; <%= new Date().getFullYear() %> IkoConnect</p>
  </footer>
  <div id="toast" class="toast"></div>

</body>
</html>
