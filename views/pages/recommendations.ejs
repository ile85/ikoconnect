<%- include('../partials/header') %>

<section class="text-center">
  <h2 class="mb-3">🔗 Recommended Tools</h2>
  <p class="mb-4">Our top picks for freelancers & remote workers</p>

  <div class="grid">
    <% tools.forEach(tool => { %>
      <div class="tool-card">
        <img src="<%= tool.logo %>" alt="<%= tool.name %> logo" />
        <h3><%= tool.name %></h3>
        <p><%= tool.description %></p>
        <a href="<%= tool.url %>" class="btn" target="_blank">Try <%= tool.name %></a>
      </div>
    <% }) %>
  </div>
</section>

<%- include('../partials/footer') %>
