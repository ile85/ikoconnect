<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IkoConnect | Remote Work & Freelancing Hub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <h1>Welcome to IkoConnect</h1>
    <p>Your ultimate resource for remote work, freelancing tips, and productivity tools.</p>
  </header>

  <section>
    <h2>Start Your Freelance Journey</h2>
    <p>Browse job opportunities, discover new tools, or subscribe to our newsletter!</p>
    <form action="/subscribe" method="POST">
      <input type="email" name="email" placeholder="Enter your email" required>
      <button type="submit">Subscribe</button>
    </form>
  </section>

  <footer>
    <p>&copy; <%= new Date().getFullYear() %> IkoConnect. All rights reserved.</p>
  </footer>
  <div id="toast" class="toast"></div>

</body>
</html>
