<!DOCTYPE html>
<html lang="en">
<%- include('../partials/header') %>

<!-- ✅ ABOUT US PAGE -->
<section id="about">
    <div class="container">
        <h1>About IkoConnect</h1>
        <p>Your trusted platform for freelancers worldwide.</p>
        <!-- 🔹 Our Story -->
    <div class="story-section">
        <h2>Our Journey</h2>
        <p>IkoConnect was founded with the vision of helping freelancers navigate the remote work industry. 
            Since our launch, we have empowered thousands of professionals to find new job opportunities and improve their careers.</p>
    </div>

        <!-- 🔹 Team Section -->
        <div class="team-section">
            <h2>Meet Our Team</h2>
            <div class="team-container">
                <div class="team-member">
                    <img src="/images/team-member1.jpg" alt="Team Member 1">
                    <h3>Ilcho Dimeski</h3>
                    <p>CEO & Founder</p>
                </div>
                <div class="team-member">
                    <img src="/images/team-member2.jpg" alt="Team Member 2">
                    <h3>Jane Smith</h3>
                    <p>Head of Operations</p>
                </div>
                <div class="team-member">
                    <img src="/images/team-member3.jpg" alt="Team Member 3">
                    <h3>Mike Johnson</h3>
                    <p>Marketing Lead</p>
                </div>
            </div>
        </div>

        <!-- 🔹 Infographic Section -->
        <div class="infographic">
            <h2>Our Achievements</h2>
            <div class="stats-container">
                <div class="stat">
                    <h3>10,000+</h3>
                    <p>Freelancers Supported</p>
                </div>
                <div class="stat">
                    <h3>500+</h3>
                    <p>Job Opportunities Listed</p>
                </div>
                <div class="stat">
                    <h3>4.9/5</h3>
                    <p>User Satisfaction</p>
                </div>
            </div>
        </div>
        <!-- 🔹 Join Our Community CTA -->
        <div class="cta-section">
            <h2>Join Our Freelance Community</h2>
            <p>Become a part of a growing network of freelancers worldwide.</p>
            <a href="/signup" class="cta-btn">Join Now</a>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
</html>
