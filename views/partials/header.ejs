<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Dynamic Title -->
  <% if (typeof originalUrl !== 'undefined') { %>
    <link rel="canonical" href="https://www.ikoconnect.com<%= originalUrl %>" />
  <% } else { %>
    <link rel="canonical" href="https://www.ikoconnect.com/" />
  <% } %>


  <!-- Meta Description -->
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Tips, tools, and jobs for freelancers and remote workers.' %>">

  <!-- Keywords (from tags) -->
  <% if (typeof tags !== 'undefined') { %>
    <meta name="keywords" content="<%= tags.join(', ') %>">
  <% } else { %>
    <meta name="keywords" content="freelancing, remote work, productivity, tools, jobs">
  <% } %>

  <!-- Author -->
  <meta name="author" content="IkoConnect">

  <!-- Open Graph / Facebook -->
  <% if (typeof post !== "undefined") { %>
    <meta property="og:title" content="<%= post.title %>" />
    <meta property="og:description" content="<%= post.description %>" />
    <meta property="og:image" content="https://www.ikoconnect.com/api/og-image?title=<%= encodeURIComponent(post.title) %>&description=<%= encodeURIComponent(post.description) %>" />
    <meta property="og:type" content="article" />
    <meta property="og:url" content="https://www.ikoconnect.com/blog/<%= post.slug %>" />
  <% } %>

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'IkoConnect' %>">
  <meta name="twitter:description" content="<%= typeof description !== 'undefined' ? description : 'Join the future of work with our freelancer tips and remote job tools.' %>">
  <meta name="twitter:image" content="https://www.ikoconnect.com/images/apple-touch-icon.jpg">

  




  <!-- JSON-LD Structured Data -->
  <% if (typeof jsonLd !== 'undefined') { %>
    <script type="application/ld+json">
      <%= jsonLd %>
    </script>
  <% } %>

  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
