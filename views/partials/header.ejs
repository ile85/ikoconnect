<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || "IkoConnect" %></title>
    <meta name="description" content="<%= description || 'Your ultimate resource for remote work and freelancing.' %>">
    
    <!-- ✅ Load CSS -->
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    
    <!-- ✅ JavaScript -->
    <script src="/js/script.js" defer></script>

    <!-- ✅ Favicon -->
    <link rel="icon" type="image/png" href="/images/favicon.png">
</head>

<body>
    <header>
        <nav class="navbar">
            <div class="logo">
                <a href="/">IkoConnect</a>
            </div>

            <!-- ✅ Desktop Navigation (Visible on large screens) -->
            <ul class="nav-links" id="desktop-menu">
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/blog">Blog</a></li>
                <li><a href="/jobs">Jobs</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>

            <!-- ✅ Hamburger Menu (For Mobile) -->
            <div id="hamburger-menu" class="hamburger-menu">
                <button class="hamburger-btn">☰</button>
            </div>
        </nav>
    </header>

    <!-- ✅ Mobile Navigation Menu (for small screens only) -->
    <nav id="mobile-menu" class="mobile-nav">
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/jobs">Jobs</a></li>
            <li><a href="/contact">Contact</a></li>
        </ul>
    </nav>
