<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="IkoConnect - Your ultimate resource for freelancers. Get the best job resources, remote work tips, and tool reviews.">
    <meta name="keywords" content="freelancing, remote work, job resources, productivity, time management">
    <meta name="author" content="IkoConnect">
    
    <title>IkoConnect | Empower Your Freelance Career</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="/images/favicon.ico">
</head>
<body>
    <!-- Navigation -->
    <header>
        <nav>
            <a href="/" class="logo">IkoConnect</a>
            <button class="hamburger" id="hamburger">
                <span class="line"></span>
                <span class="line"></span>
                <span class="line"></span>
            </button>
            <div class="menu" id="menu">
                <a href="#about">About</a>
                <a href="#blog">Blog</a>
                <a href="#resources">Resources</a>
                <a href="#jobs">Jobs</a>
                <a href="#newsletter">Newsletter</a>
            </div>
        </nav>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Take Your Freelance Career to the Next Level</h1>
            <p>Join thousands of freelancers growing their careers with expert tips, job resources, and top productivity tools.</p>
            <a href="#jobs" class="cta-btn primary">Find Freelance Jobs</a>
            <a href="#newsletter" class="cta-btn secondary">Get Free Tips</a>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="animate-on-scroll">
        <h2>What is IkoConnect?</h2>
        <p>IkoConnect is your go-to platform for everything freelance. We help remote workers succeed with job listings, productivity tools, and expert insights.</p>
        <a href="/about" class="cta-btn">Learn More</a>
    </section>

    <!-- Testimonial Slider -->
    <div class="slider animate-on-scroll">
        <div class="slides">
            <div class="slide active">
                <h3>⭐ Alex D.</h3>
                <p>"IkoConnect helped me land my first big freelancing gig! The job resources are amazing!"</p>
            </div>
            <div class="slide">
                <h3>⭐ Maria K.</h3>
                <p>"From job listings to productivity hacks, IkoConnect is a game-changer for freelancers."</p>
            </div>
            <div class="slide">
                <h3>⭐ John R.</h3>
                <p>"The tools recommended by IkoConnect have made managing my projects much easier!"</p>
            </div>
        </div>
        <button class="slider-btn prev">‹</button>
        <button class="slider-btn next">›</button>
    </div>

    <!-- Blog Section -->
    <section id="blog" class="animate-on-scroll">
        <h2>Latest Freelancing Tips</h2>
        <p>Discover expert tips on freelancing, productivity, and remote work success.</p>
        <a href="/blog" class="cta-btn">Read the Blog</a>
    </section>

    <!-- Resources Section -->
    <section id="resources" class="animate-on-scroll">
        <h2>Essential Tools for Freelancers</h2>
        <p>We provide a curated list of the best tools to help you stay productive and manage your freelance business efficiently.</p>
        <a href="/resources" class="cta-btn">Explore Resources</a>
    </section>

    <!-- Jobs Section -->
    <section id="jobs" class="animate-on-scroll">
        <h2>Find Remote Jobs</h2>
        <p>Browse handpicked freelance job listings from platforms like Upwork, Fiverr, and more.</p>
        <a href="/jobs" class="cta-btn">Browse Jobs</a>
    </section>

    <!-- Newsletter Signup Section -->
    <section id="newsletter" class="animate-on-scroll">
        <h2>Join Our Freelancer Community</h2>
        <p>Get exclusive freelancing tips and job alerts straight to your inbox.</p>
        <form action="/subscribe" method="POST">
            <input type="email" name="email" placeholder="Enter your email" required>
            <button type="submit" class="cta-btn">Subscribe Now</button>
        </form>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <p>&copy; 2024 IkoConnect. All Rights Reserved.</p>
            <div class="footer-links">
                <a href="#about">About</a>
                <a href="#blog">Blog</a>
                <a href="#resources">Resources</a>
                <a href="#jobs">Jobs</a>
                <a href="#newsletter">Newsletter</a>
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="/js/main.js"></script>
</body>
</html>
