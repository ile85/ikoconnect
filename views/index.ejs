<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IkoConnect | Empower Your Freelance Career</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="/images/favicon.ico">
</head>
<body>
    <!-- Navigation -->
    <header>
        <nav>
            <a href="/" class="logo">IkoConnect</a>
            <button class="hamburger" id="hamburger">
                <span class="line"></span>
                <span class="line"></span>
                <span class="line"></span>
            </button>
            <div class="menu" id="menu">
                <a href="#about">About</a>
                <a href="#blog">Blog</a>
                <a href="#resources">Resources</a>
                <a href="#jobs">Jobs</a>
                <a href="#newsletter">Newsletter</a>
            </div>
        </nav>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Empower Your Freelance Career</h1>
            <p>Get the tools, resources, and job opportunities to build a successful remote career.</p>
            <a href="#about" class="cta-btn">Get Started</a>
            <a href="#resources" class="cta-btn cta-secondary">Explore Resources</a>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="animate-on-scroll">
        <h2>About IkoConnect</h2>
        <p>IkoConnect is designed to provide freelancers and remote workers with the tools and resources needed to succeed in the digital economy. Our mission is to empower individuals to thrive in a remote work environment.</p>
        <a href="/about" class="cta-btn">Learn More</a>
    </section>

    <!-- Testimonial Slider -->
    <div class="slider animate-on-scroll">
        <div class="slides">
            <div class="slide active">
                <h3>Testimonial 1</h3>
                <p>"IkoConnect has completely transformed the way I approach freelancing. The resources are invaluable!"</p>
            </div>
            <div class="slide">
                <h3>Testimonial 2</h3>
                <p>"From job listings to productivity tips, IkoConnect has been a game-changer for my remote work life."</p>
            </div>
            <div class="slide">
                <h3>Testimonial 3</h3>
                <p>"The tools recommended by IkoConnect have made managing my projects a breeze!"</p>
            </div>
        </div>
        <button class="slider-btn prev">Prev</button>
        <button class="slider-btn next">Next</button>
    </div>

    <!-- Blog Section -->
    <section id="blog" class="animate-on-scroll">
        <h2>Latest Blog Posts</h2>
        <p>Stay updated with our blog posts on remote work, freelancing, and productivity. We cover everything from tool reviews to job platform tips.</p>
        <a href="/blog" class="cta-btn">Read Blog</a>
    </section>

    <!-- Resources Section -->
    <section id="resources" class="animate-on-scroll">
        <h2>Resources</h2>
        <p>We offer a curated list of the best tools and platforms to help manage your freelance career. From project management to time tracking, we have you covered.</p>
        <a href="/resources" class="cta-btn">Explore Resources</a>
    </section>

    <!-- Jobs Section -->
    <section id="jobs" class="animate-on-scroll">
        <h2>Freelance Jobs</h2>
        <p>Find freelance opportunities from top platforms like Upwork, Fiverr, and FlexJobs. Start your remote career today!</p>
        <a href="/jobs" class="cta-btn">Find Jobs</a>
    </section>

    <!-- Newsletter Signup Section -->
    <section id="newsletter" class="animate-on-scroll">
        <h2>Join Our Newsletter</h2>
        <p>Stay informed with the latest tips, tools, and job updates for freelancers.</p>
        <form action="/subscribe" method="POST">
            <input type="email" name="email" placeholder="Enter your email" required>
            <button type="submit" class="cta-btn">Subscribe</button>
        </form>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <p>&copy; 2024 IkoConnect. All Rights Reserved.</p>
            <div class="footer-links">
                <a href="#about">About</a>
                <a href="#blog">Blog</a>
                <a href="#resources">Resources</a>
                <a href="#jobs">Jobs</a>
                <a href="#newsletter">Newsletter</a>
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="/js/main.js"></script>
</body>
</html>
